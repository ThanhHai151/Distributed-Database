# QLNS Distributed Web App — Environment Config
# Copy file này thành .env và điều chỉnh theo môi trường

# ============================================================
# SERVER CONFIG
# ============================================================
PORT=4000
HOST=0.0.0.0
NODE_ENV=development

# ============================================================
# DISTRIBUTED QUERY MODE
# linked   = dùng Linked Servers qua Master (Docker/Linux)
# direct   = connect trực tiếp 4 pools song song (Universal)
# replication = Windows SQL Server Replication mode
# ============================================================
QUERY_MODE=direct

# ============================================================
# SQL SERVER CONNECTIONS
# ============================================================
# Master Server (toàn bộ dữ liệu + Linked Servers)
MASTER_HOST=localhost
MASTER_PORT=1432
MASTER_USER=sa
MASTER_PASSWORD=KetNoi@123
MASTER_DB=QuanLyNhanSu

# Chi nhánh CN1 — Hà Nội
CN1_HOST=localhost
CN1_PORT=1437
CN1_USER=sa
CN1_PASSWORD=KetNoi@123
CN1_DB=QuanLyNhanSu

# Chi nhánh CN2 — Đà Nẵng
CN2_HOST=localhost
CN2_PORT=1435
CN2_USER=sa
CN2_PASSWORD=KetNoi@123
CN2_DB=QuanLyNhanSu

# Chi nhánh CN3 — TP. Hồ Chí Minh
CN3_HOST=localhost
CN3_PORT=1436
CN3_USER=sa
CN3_PASSWORD=KetNoi@123
CN3_DB=QuanLyNhanSu

# ============================================================
# CONNECTION POOL CONFIG
# ============================================================
DB_POOL_MAX=10
DB_POOL_MIN=2
DB_CONNECT_TIMEOUT=15000
DB_REQUEST_TIMEOUT=30000
